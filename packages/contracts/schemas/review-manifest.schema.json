{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openreviewatlas.example/schemas/review-manifest-1.0.0.json",
  "title": "Open Review Atlas review manifest",
  "description": "Optional machine-readable manifest placed at review-manifest.json in the root of a computational-review repository. Version 1.0.0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "review", "repository"],
  "$defs": {
    "safeRepoRelativePath": {
      "type": "string",
      "maxLength": 512,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*(/[A-Za-z0-9][A-Za-z0-9._-]*)*$",
      "description": "Repository-relative path. No absolute paths, no '..', no schemes, no backslashes."
    },
    "doi": {
      "type": "string",
      "pattern": "^10\\.\\d{4,9}/\\S+$",
      "description": "Bare DOI (10.xxxx/suffix). Do not include doi: or https://doi.org/ prefixes."
    },
    "orcid": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[\\dX]$"
    },
    "httpsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "contributor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["displayName"],
      "properties": {
        "displayName": { "type": "string", "minLength": 1, "maxLength": 300 },
        "givenName": { "type": "string", "maxLength": 150 },
        "familyName": { "type": "string", "maxLength": 150 },
        "orcid": { "$ref": "#/$defs/orcid" },
        "githubLogin": { "type": "string", "maxLength": 39 },
        "roles": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "maxLength": 80 }
        }
      }
    }
  },
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "abstract": { "type": "string", "maxLength": 10000 },
        "reviewType": {
          "enum": [
            "computational-literature-review",
            "systematic-review",
            "scoping-review",
            "narrative-review",
            "meta-analysis",
            "other"
          ]
        },
        "language": { "type": "string", "pattern": "^[a-z]{2}(-[A-Za-z]{2,8})?$" },
        "keywords": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        },
        "domains": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        },
        "license": { "type": "string", "maxLength": 120 }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": { "$ref": "#/$defs/httpsUrl" },
        "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "releaseTag": { "type": "string", "maxLength": 120 }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewUrl": { "$ref": "#/$defs/httpsUrl" },
        "versionDoi": { "$ref": "#/$defs/doi" },
        "conceptDoi": { "$ref": "#/$defs/doi" },
        "zenodoRecordId": { "type": "string", "pattern": "^\\d+$" }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "maxLength": 300 },
        "orcid": { "$ref": "#/$defs/orcid" },
        "url": { "$ref": "#/$defs/httpsUrl" }
      }
    },
    "contributors": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/contributor" }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claims": { "$ref": "#/$defs/safeRepoRelativePath" },
        "citations": { "$ref": "#/$defs/safeRepoRelativePath" },
        "relations": { "$ref": "#/$defs/safeRepoRelativePath" },
        "trustAssessments": { "$ref": "#/$defs/safeRepoRelativePath" },
        "provenance": { "$ref": "#/$defs/safeRepoRelativePath" }
      }
    }
  }
}
