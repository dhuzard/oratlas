{
  "name": "@oratlas/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:validate": "prisma validate",
    "db:pg:schema": "tsx scripts/gen-postgres-schema.ts",
    "db:pg:ddl": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.postgres.prisma --script > prisma/schema.postgres.sql",
    "db:seed": "tsx src/seed/seed.ts",
    "db:backfill-github-logins": "tsx src/backfill-github-logins.ts",
    "db:reconcile-github-repositories": "tsx src/reconcile-github-repositories.ts",
    "db:reset": "tsx src/seed/reset.ts && prisma db push --skip-generate && tsx src/seed/seed.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@oratlas/contracts": "workspace:*",
    "@oratlas/trust": "workspace:*",
    "@prisma/client": "^6.8.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "prisma": "^6.8.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
