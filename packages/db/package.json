{
  "name": "@oratlas/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:validate": "prisma validate",
    "db:seed": "tsx src/seed/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx src/seed/seed.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@oratlas/contracts": "workspace:*",
    "@prisma/client": "^6.8.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "prisma": "^6.8.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
