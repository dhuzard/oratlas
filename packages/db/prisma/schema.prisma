// Open Review Atlas — core data model (spec §9).
//
// SQLite for zero-configuration local development; the schema deliberately
// avoids SQLite-only and Postgres-only features so switching the datasource
// provider to "postgresql" is a configuration change:
//   - enums are String columns validated by @oratlas/contracts at the app layer
//   - JSON payloads are String columns containing JSON ("...Json" suffix)
//   - arrays (topics, roles, keywords) are JSON-encoded String columns
generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  githubUserId          String?   @unique
  githubLogin           String    @unique
  /// NFKC + lowercase login used solely for collision prevention.
  /// Transitional: application-enforced uniqueness until issue #7.
  githubLoginNormalized String?
  displayName           String?
  avatarUrl             String?
  profileUrl            String?
  /// USER | EDITOR | ADMIN
  role                  String    @default("USER")
  /// Reviewer ORCID iD (contracts orcidSchema). Unverified until an ORCID
  /// sign-in confirms it; reports snapshot the verification state.
  orcid                 String?
  orcidVerifiedAt       DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  submissions                    Submission[]                    @relation("submitter")
  editorialDecisions             Submission[]                    @relation("reviewer")
  discussionThreads              DiscussionThread[]
  reviewComments                 ReviewComment[]
  auditEvents                    AuditEvent[]
  trustVerifications             TrustVerification[]             @relation("trustReviewer")
  nodeRelationTrustVerifications NodeRelationTrustVerification[] @relation("nodeRelationTrustReviewer")
  inspectionCaptures             InspectionCapture[]
  editorialOverrides             EditorialOverride[]
  lifecycleEvents                ReviewLifecycleEvent[]          @relation("lifecycleActor")
  editorAssignments              EditorAssignment[]              @relation("assignmentEditor")
  assignmentsMade                EditorAssignment[]              @relation("assignmentAssigner")
  roundsOpened                   ReviewRound[]                   @relation("roundOpener")
  formalReports                  FormalReviewReport[]            @relation("formalReviewer")
  authorResponses                AuthorResponse[]                @relation("respondingAuthor")
  decisionLetters                DecisionLetter[]                @relation("decisionEditor")
  notifications                  Notification[]                  @relation("notificationUser")
  statusRecords                  CitationStatusRecord[]          @relation("statusRecorder")
  proposalsResolved              ClaimUpdateProposal[]           @relation("proposalResolver")
  protocolSnapshots              ProtocolSnapshot[]              @relation("protocolSnapshotCreator")
  protocolProposalsResolved      ProtocolDriftProposal[]         @relation("protocolProposalResolver")
  passportsRegistered            ExecutionPassport[]             @relation("passportRegistrant")
  passportsVerified              ExecutionPassport[]             @relation("passportVerifier")
  federationResolved             FederationNotification[]        @relation("federationResolver")
  replicationBriefsCreated       ReplicationBrief[]              @relation("replicationCreator")
  replicationBriefsPublished     ReplicationBrief[]              @relation("replicationPublisher")
  replicationBriefsClaimed       ReplicationBrief[]              @relation("replicationClaimant")
  replicationBriefsCompleted     ReplicationBrief[]              @relation("replicationCompleter")
  replicationBriefsWithdrawn     ReplicationBrief[]              @relation("replicationWithdrawer")
  nodeEdgeProposalsReviewed      NodeEdgeProposal[]              @relation("nodeEdgeProposalReviewer")
  nodeEdgesConfirmed             NodeEdge[]                      @relation("nodeEdgeConfirmer")

  @@index([githubLoginNormalized])
}

model Repository {
  id                 String    @id @default(cuid())
  /// Always "github.com" in the POC.
  host               String    @default("github.com")
  owner              String
  name               String
  canonicalUrl       String    @unique
  /// Immutable GitHub database id. Decimal string avoids 32-bit truncation.
  githubRepositoryId String?   @unique
  defaultBranch      String?
  description        String?
  licenseSpdx        String?
  /// JSON array of topic strings.
  topicsJson         String    @default("[]")
  homepageUrl        String?
  pagesUrl           String?
  isArchived         Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastInspectedAt    DateTime?

  snapshots      RepositorySnapshot[]
  submissions    Submission[]
  reviews        Review[]
  knowledgeNodes KnowledgeNode[]

  @@unique([host, owner, name])
}

model RepositorySnapshot {
  id                   String    @id @default(cuid())
  repositoryId         String
  commitSha            String
  /// Legacy selection fields. New writes keep source selection on Submission
  /// and ReviewVersion because one commit can be reached through many refs.
  branch               String?
  releaseTag           String?
  releaseUrl           String?
  /// When the commit/release was created on GitHub.
  sourceCreatedAt      DateTime?
  capturedAt           DateTime  @default(now())
  /// succeeded | partial | failed
  inspectionStatus     String
  inspectionReportJson String
  /// Git tree object belonging to commitSha.
  sourceTreeSha        String?
  /// default-branch | tag | release
  sourceKind           String?
  /// Validated review manifest content, when present.
  manifestJson         String?
  /// Durable canonical-JSON copy of preserved textual file contents
  /// (contracts preservedFilesSchema), written at submission so preservation
  /// never depends on the ephemeral inspect-to-submit capability row.
  preservedFilesJson   String?
  /// SHA-256 over the normalized inspection payload (integrity/versioning aid).
  contentHash          String

  repository            Repository             @relation(fields: [repositoryId], references: [id])
  submissions           Submission[]
  reviewVersions        ReviewVersion[]
  knowledgeNodeVersions KnowledgeNodeVersion[]
  currentOf             Review[]               @relation("currentSnapshot")

  @@unique([repositoryId, commitSha])
}

model Review {
  id                 String    @id @default(cuid())
  slug               String    @unique
  /// Stable repository identity; prevents concurrent duplicate review rows.
  repositoryId       String?   @unique
  currentSnapshotId  String?
  title              String
  abstract           String?
  /// contracts REVIEW_TYPES
  reviewType         String?
  licenseSpdx        String?
  publishedReviewUrl String?
  /// published | withdrawn | superseded
  status             String    @default("published")
  acceptedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  /// Optimistic-concurrency counter for append-only public lifecycle events.
  lifecycleRevision  Int       @default(0)

  currentSnapshot RepositorySnapshot?    @relation("currentSnapshot", fields: [currentSnapshotId], references: [id])
  repository      Repository?            @relation(fields: [repositoryId], references: [id])
  versions        ReviewVersion[]
  comments        ReviewComment[]
  lifecycleEvents ReviewLifecycleEvent[]
}

model ReviewVersion {
  id                         String    @id @default(cuid())
  reviewId                   String
  snapshotId                 String
  /// First submission that materialized this version (idempotency provenance).
  sourceSubmissionId         String?   @unique
  inspectionCaptureId        String?   @unique
  /// Exact source selection accepted for this version.
  sourceKind                 String?
  sourceBranch               String?
  sourceSelectionKey         String?
  tagObjectSha               String?
  sourceCreatedAt            DateTime?
  semanticVersion            String?
  title                      String
  abstract                   String?
  /// Effective metadata + provenance for this immutable version.
  metadataJson               String
  versionDoi                 String?
  conceptDoi                 String?
  zenodoRecordId             String?
  releaseTag                 String?
  releaseUrl                 String?
  /// Public, immutable release/DOI/commit consistency evidence.
  publicationConsistencyJson String?
  /// SHA-256 of the exact canonical inspection capture accepted here.
  capturePayloadHash         String?
  /// True when every DOI/identifier on this version is a synthetic example
  /// (seed/demo data). The UI must not render outbound resolvers for these.
  isExample                  Boolean   @default(false)
  publishedAt                DateTime?
  createdAt                  DateTime  @default(now())
  /// published | withdrawn | tombstoned. Updated only in the same
  /// transaction that appends an attributable lifecycle event.
  publicState                String    @default("published")

  review                  Review                   @relation(fields: [reviewId], references: [id])
  snapshot                RepositorySnapshot       @relation(fields: [snapshotId], references: [id])
  contributors            ReviewContributor[]
  identifiers             Identifier[]
  claims                  Claim[]
  citations               Citation[]
  comments                ReviewComment[]
  sourceSubmission        Submission?              @relation("VersionSource", fields: [sourceSubmissionId], references: [id])
  inspectionCapture       InspectionCapture?       @relation(fields: [inspectionCaptureId], references: [id])
  resultingSubmissions    Submission[]             @relation("ResultingVersion")
  lifecycleEvents         ReviewLifecycleEvent[]   @relation("lifecycleTarget")
  supersededByEvents      ReviewLifecycleEvent[]   @relation("lifecycleSupersededVersion")
  federationNotifications FederationNotification[]
  protocolSnapshots       ProtocolSnapshot[]

  @@unique([reviewId, snapshotId, sourceSelectionKey])
}

/// Corrections, withdrawals and tombstones are immutable public events. The
/// materialized ReviewVersion.publicState is only a fail-closed access guard;
/// this append-only ledger remains the attributable scholarly record.
model ReviewLifecycleEvent {
  id                  String   @id @default(cuid())
  reviewId            String
  reviewVersionId     String
  actorId             String
  /// correction | withdrawal | tombstone
  kind                String
  reason              String
  supersedesVersionId String?
  /// Resulting Review.lifecycleRevision. Unique per review supplies CAS.
  revision            Int
  createdAt           DateTime @default(now())

  review            Review         @relation(fields: [reviewId], references: [id])
  reviewVersion     ReviewVersion  @relation("lifecycleTarget", fields: [reviewVersionId], references: [id])
  supersedesVersion ReviewVersion? @relation("lifecycleSupersededVersion", fields: [supersedesVersionId], references: [id])
  actor             User           @relation("lifecycleActor", fields: [actorId], references: [id])

  @@unique([reviewId, revision])
  @@index([reviewVersionId, createdAt])
  @@index([kind, createdAt])
}

/// Server-side, opaque, expiring inspect-to-submit capability. Payloads are
/// append-only; consumption and submission creation occur in one transaction.
model InspectionCapture {
  id                    String                 @id @default(cuid())
  tokenHash             String                 @unique
  payloadJson           String
  payloadHash           String
  githubRepositoryId    String
  canonicalUrlAtCapture String
  inspectedByUserId     String
  commitSha             String
  releaseTag            String?
  createdAt             DateTime               @default(now())
  expiresAt             DateTime
  consumedAt            DateTime?
  inspectedBy           User                   @relation(fields: [inspectedByUserId], references: [id])
  submission            Submission?
  reviewVersion         ReviewVersion?
  knowledgeNodeVersions KnowledgeNodeVersion[] @relation("NodeVersionCapture")
  nodeEdgeProposals     NodeEdgeProposal[]     @relation("NodeEdgeProposalCapture")

  @@index([expiresAt])
  @@index([payloadHash])
}

model Person {
  id          String  @id @default(cuid())
  displayName String
  givenName   String?
  familyName  String?
  orcid       String?
  githubLogin String?

  contributions ReviewContributor[]
}

model ReviewContributor {
  reviewVersionId String
  personId        String
  /// JSON array of role strings (e.g. ["author"], ["maintainer"]).
  rolesJson       String @default("[]")
  position        Int

  reviewVersion ReviewVersion @relation(fields: [reviewVersionId], references: [id])
  person        Person        @relation(fields: [personId], references: [id])

  @@id([reviewVersionId, personId])
}

model Submission {
  id                         String    @id @default(cuid())
  submitterId                String
  repositoryId               String
  snapshotId                 String?
  inspectionCaptureId        String?   @unique
  /// Exact selection provenance from the consumed inspection capture.
  sourceKind                 String?
  sourceBranch               String?
  sourceSelectionKey         String?
  releaseTag                 String?
  releaseUrl                 String?
  tagObjectSha               String?
  sourceCreatedAt            DateTime?
  /// contracts SUBMISSION_STATUSES
  status                     String    @default("draft")
  extractedMetadataJson      String?
  editedMetadataJson         String?
  validationReportJson       String?
  /// Immutable snapshot of the exact payload the submitter finalized.
  submittedPayloadJson       String?
  submittedPayloadHash       String?
  /// Canonical JSON array of local node ids selected during acceptance.
  acceptedNodeSelectionJson  String?
  /// SHA-256 of acceptedNodeSelectionJson for idempotent acceptance retries.
  acceptedNodeSelectionHash  String?
  submittedAt                DateTime?
  reviewedAt                 DateTime?
  reviewerId                 String?
  editorialNote              String?
  /// Public consistency report produced from the exact captured source.
  publicationConsistencyJson String?
  /// Review created/updated when this submission was accepted.
  resultingReviewId          String?
  resultingReviewVersionId   String?
  /// Revision lineage: the changes-requested submission this one resubmits.
  previousSubmissionId       String?   @unique
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  submitter              User                   @relation("submitter", fields: [submitterId], references: [id])
  reviewer               User?                  @relation("reviewer", fields: [reviewerId], references: [id])
  repository             Repository             @relation(fields: [repositoryId], references: [id])
  snapshot               RepositorySnapshot?    @relation(fields: [snapshotId], references: [id])
  inspectionCapture      InspectionCapture?     @relation(fields: [inspectionCaptureId], references: [id])
  sourceVersion          ReviewVersion?         @relation("VersionSource")
  resultingReviewVersion ReviewVersion?         @relation("ResultingVersion", fields: [resultingReviewVersionId], references: [id])
  sourceNodeVersions     KnowledgeNodeVersion[] @relation("NodeVersionSource")
  editorialOverrides     EditorialOverride[]
  previousSubmission     Submission?            @relation("Resubmission", fields: [previousSubmissionId], references: [id])
  resubmission           Submission?            @relation("Resubmission")
  editorAssignments      EditorAssignment[]
  reviewRounds           ReviewRound[]
  nodeEdgeProposals      NodeEdgeProposal[]     @relation("NodeEdgeProposalSubmission")
}

/// An explicit, check-scoped editorial exception. Overrides never rewrite the
/// consistency report and are immutable once acceptance commits.
model EditorialOverride {
  id           String   @id @default(cuid())
  submissionId String
  checkId      String
  rationale    String
  editorId     String
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])
  editor     User       @relation(fields: [editorId], references: [id])

  @@unique([submissionId, checkId])
  @@index([editorId])
}

model Identifier {
  id                   String  @id @default(cuid())
  reviewVersionId      String
  /// doi | github | orcid | url | zenodo-record
  scheme               String
  value                String
  normalizedValue      String
  url                  String?
  /// version-doi | concept-doi | repository | release | published-review | zenodo-record | author-orcid
  relationType         String
  /// unvalidated | valid | valid-with-warnings | invalid | example-not-resolvable
  validationStatus     String  @default("unvalidated")
  validationReportJson String?
  /// Synthetic example identifier — never render as an outbound link.
  isExample            Boolean @default(false)

  reviewVersion ReviewVersion @relation(fields: [reviewVersionId], references: [id])

  @@index([scheme, normalizedValue])
}

model Claim {
  id              String   @id @default(cuid())
  reviewVersionId String
  /// Optional bridge from legacy review claims to a stable publication node.
  /// Existing rows remain valid and are not destructively backfilled.
  knowledgeNodeId String?
  /// Identifier within the source repository artifacts (e.g. "claim-003").
  localClaimId    String
  text            String
  normalizedText  String
  section         String?
  anchor          String?
  /// contracts CLAIM_TYPES
  claimType       String?
  qualification   String?
  /// Declared comparison scope (contracts claimScopeSchema JSON), for
  /// independence-aware synthesis. Absent when the repository declared none.
  scopeJson       String?
  createdAt       DateTime @default(now())

  reviewVersion      ReviewVersion            @relation(fields: [reviewVersionId], references: [id])
  knowledgeNode      KnowledgeNode?           @relation(fields: [knowledgeNodeId], references: [id])
  evidenceRelations  ClaimEvidenceRelation[]
  linkProposalsFrom  KnowledgeLinkProposal[]  @relation("sourceClaim")
  linkProposalsTo    KnowledgeLinkProposal[]  @relation("targetClaim")
  comments           ReviewComment[]
  updateProposals    ClaimUpdateProposal[]
  protocolSnapshots  ProtocolSnapshot[]
  executionPassports ExecutionPassportClaim[]
  replicationBriefs  ReplicationBriefClaim[]

  @@unique([reviewVersionId, localClaimId])
  @@index([knowledgeNodeId])
}

/// Stable concept identity for one repository-local publication node. Content
/// lives only in immutable KnowledgeNodeVersion snapshots.
model KnowledgeNode {
  id           String   @id @default(cuid())
  repositoryId String
  localNodeId  String
  /// contracts KNOWLEDGE_NODE_KINDS: claim | figure | dataset | code
  kind         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository            Repository             @relation(fields: [repositoryId], references: [id])
  versions              KnowledgeNodeVersion[]
  incomingEdges         NodeEdge[]             @relation("targetNode")
  incomingEdgeProposals NodeEdgeProposal[]     @relation("proposalTargetNode")
  linkedClaims          Claim[]
  aliases               NodeAlias[]

  @@unique([repositoryId, localNodeId])
  @@index([kind])
}

/// Immutable content snapshot for a node at one exact repository commit. The
/// bound RepositorySnapshot supplies the commit SHA without duplicating it.
model KnowledgeNodeVersion {
  id                  String   @id @default(cuid())
  knowledgeNodeId     String
  snapshotId          String
  /// Submission/capture that first materialized this version. A single
  /// acceptance can publish many nodes, so these provenance FKs are not unique.
  sourceSubmissionId  String?
  inspectionCaptureId String?
  /// SHA-256 of the exact canonical inspection capture accepted here.
  capturePayloadHash  String?
  title               String
  abstract            String?
  text                String?
  /// contracts ManifestContributor[] encoded as JSON.
  contributorsJson    String   @default("[]")
  license             String
  /// contracts KnowledgeNodeProvenance encoded as JSON.
  provenanceJson      String
  /// Kind-specific contracts KnowledgeNode.payload encoded as JSON.
  payloadJson         String
  versionDoi          String?
  conceptDoi          String?
  /// Synthetic example identifier marker; never render its DOI as outbound.
  isExample           Boolean  @default(false)
  createdAt           DateTime @default(now())

  knowledgeNode     KnowledgeNode      @relation(fields: [knowledgeNodeId], references: [id])
  snapshot          RepositorySnapshot @relation(fields: [snapshotId], references: [id])
  sourceSubmission  Submission?        @relation("NodeVersionSource", fields: [sourceSubmissionId], references: [id])
  inspectionCapture InspectionCapture? @relation("NodeVersionCapture", fields: [inspectionCaptureId], references: [id])
  outgoingEdges     NodeEdge[]         @relation("sourceNodeVersion")
  proposedEdgesFrom NodeEdgeProposal[] @relation("proposalSourceVersion")
  proposedAsTarget  NodeEdgeProposal[] @relation("proposalTargetVersion")
  confirmedAsTarget NodeEdge[]         @relation("confirmedTargetVersion")

  @@unique([knowledgeNodeId, snapshotId])
  @@index([snapshotId])
  @@index([sourceSubmissionId])
  @@index([inspectionCaptureId])
}

/// Directed, typed relation asserted from an immutable source version to a
/// stable target identity. Status and provenance use @oratlas/contracts enums.
model NodeEdge {
  id                           String    @id @default(cuid())
  sourceNodeVersionId          String
  targetNodeId                 String
  relationType                 String
  status                       String
  provenance                   String
  rationale                    String?
  assertedAt                   DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
  confirmedTargetNodeVersionId String?
  confirmedById                String?
  confirmedAt                  DateTime?
  revision                     Int       @default(0)

  sourceNodeVersion          KnowledgeNodeVersion  @relation("sourceNodeVersion", fields: [sourceNodeVersionId], references: [id])
  targetNode                 KnowledgeNode         @relation("targetNode", fields: [targetNodeId], references: [id])
  confirmedTargetNodeVersion KnowledgeNodeVersion? @relation("confirmedTargetVersion", fields: [confirmedTargetNodeVersionId], references: [id])
  confirmedBy                User?                 @relation("nodeEdgeConfirmer", fields: [confirmedById], references: [id])
  proposals                  NodeEdgeProposal[]    @relation("confirmedProposalEdge")

  @@unique([sourceNodeVersionId, targetNodeId, relationType])
  @@index([targetNodeId])
  @@index([status, relationType])
  @@index([confirmedTargetNodeVersionId])
}

/// An attributable author assertion or agent proposal. Editorial confirmation
/// materializes the separate NodeEdge while preserving this immutable origin.
model NodeEdgeProposal {
  id                  String    @id @default(cuid())
  originKey           String    @unique
  sourceStableKey     String
  targetStableKey     String
  sourceNodeVersionId String
  targetNodeId        String
  targetNodeVersionId String
  relationType        String
  /// asserted-by-author | proposed-by-agent
  origin              String
  rationale           String?
  evidenceJson        String    @default("{}")
  sourceSubmissionId  String?
  inspectionCaptureId String?
  agentRunId          String?
  /// proposed | confirmed | rejected | superseded
  status              String    @default("proposed")
  revision            Int       @default(0)
  reviewedById        String?
  reviewedAt          DateTime?
  reviewNote          String?
  confirmedEdgeId     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sourceNodeVersion KnowledgeNodeVersion          @relation("proposalSourceVersion", fields: [sourceNodeVersionId], references: [id])
  targetNode        KnowledgeNode                 @relation("proposalTargetNode", fields: [targetNodeId], references: [id])
  targetNodeVersion KnowledgeNodeVersion          @relation("proposalTargetVersion", fields: [targetNodeVersionId], references: [id])
  sourceSubmission  Submission?                   @relation("NodeEdgeProposalSubmission", fields: [sourceSubmissionId], references: [id])
  inspectionCapture InspectionCapture?            @relation("NodeEdgeProposalCapture", fields: [inspectionCaptureId], references: [id])
  agentRun          AgentRun?                     @relation(fields: [agentRunId], references: [id])
  reviewedBy        User?                         @relation("nodeEdgeProposalReviewer", fields: [reviewedById], references: [id])
  confirmedEdge     NodeEdge?                     @relation("confirmedProposalEdge", fields: [confirmedEdgeId], references: [id])
  trustAssessments  NodeRelationTrustAssessment[]

  @@index([status, createdAt])
  @@index([sourceNodeVersionId])
  @@index([targetNodeId])
  @@index([confirmedEdgeId])
}

/// Canonical DOI/PMID/OpenAlex comparison key declared for a stable node.
/// The role remains explicit so version and concept DOI meaning is never lost.
/// Alias values are intentionally not globally unique: a shared value produces
/// a reviewable identity proposal and never merges the owning nodes.
model NodeAlias {
  id              String   @id @default(cuid())
  knowledgeNodeId String
  /// contracts nodeAliasSchemeSchema: doi | pmid | openalex
  scheme          String
  /// contracts nodeAliasRoleSchema; version/concept/artifact/work stay distinct.
  role            String
  /// Canonical value without a resolver/prefix (for example 10.1000/work).
  value           String
  /// Synthetic examples are stored for provenance but excluded from matching.
  isExample       Boolean  @default(false)
  createdAt       DateTime @default(now())

  knowledgeNode KnowledgeNode @relation(fields: [knowledgeNodeId], references: [id])

  @@unique([knowledgeNodeId, scheme, role, value])
  @@index([scheme, value])
}

/// A human-editor-published replication opportunity. Triage snapshots are
/// deterministic evidence-gap metadata only; they are never scientific truth
/// scores, outcome predictions, or rankings of the people who claim briefs.
model ReplicationBrief {
  id                      String    @id @default(cuid())
  requestKey              String    @unique
  requestHash             String
  slug                    String    @unique
  title                   String
  summary                 String
  scopeJson               String
  expectedInformationGain String
  effortBand              String
  protocolUrl             String?
  citationUrlsJson        String    @default("[]")
  /// draft | open | claimed | completed | withdrawn
  status                  String    @default("draft")
  /// Optimistic-concurrency counter for every lifecycle transition.
  revision                Int       @default(0)
  /// Snapshot of rule ids/counts at publication; no scalar score.
  triageSnapshotJson      String?
  createdById             String
  publishedById           String?
  publishedAt             DateTime?
  claimedById             String?
  claimedAt               DateTime?
  claimNote               String?
  completedById           String?
  completedAt             DateTime?
  completionUrl           String?
  completionSummary       String?
  withdrawnById           String?
  withdrawnAt             DateTime?
  withdrawalReason        String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  createdBy   User                    @relation("replicationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  publishedBy User?                   @relation("replicationPublisher", fields: [publishedById], references: [id], onDelete: Restrict)
  claimedBy   User?                   @relation("replicationClaimant", fields: [claimedById], references: [id], onDelete: Restrict)
  completedBy User?                   @relation("replicationCompleter", fields: [completedById], references: [id], onDelete: Restrict)
  withdrawnBy User?                   @relation("replicationWithdrawer", fields: [withdrawnById], references: [id], onDelete: Restrict)
  claims      ReplicationBriefClaim[]

  @@index([status, publishedAt])
  @@index([effortBand, status])
  @@index([claimedById, status])
}

model ReplicationBriefClaim {
  replicationBriefId String
  claimId            String
  position           Int

  replicationBrief ReplicationBrief @relation(fields: [replicationBriefId], references: [id])
  claim            Claim            @relation(fields: [claimId], references: [id])

  @@id([replicationBriefId, claimId])
  @@unique([replicationBriefId, position])
  @@index([claimId])
}

/// Offline-verified execution provenance bound to immutable Atlas claims.
/// Submitted repositories are never cloned or executed. Source JSON retains
/// the exact bounded crate/envelope so verification can be repeated later.
model ExecutionPassport {
  id                 String   @id @default(cuid())
  /// Always execution-attested for a valid public record. This label does not
  /// assert that results were reproduced or that a claim is scientifically true.
  status             String   @default("execution-attested")
  /// verified | failed. Public reads require verified and re-check hashes.
  verificationStatus String   @default("verified")
  revision           Int      @default(0)
  sourceJson         String
  crateSha256        String
  attestationSha256  String
  /// Canonical signed statement identity; envelope signature-array changes
  /// cannot create duplicate passports for the same attested execution.
  payloadSha256      String   @unique
  repositoryUrl      String
  commitSha          String
  treeSha            String
  workflowEntityId   String
  workflowPath       String
  workflowSha256     String
  workflowRunId      String
  workflowRunAttempt Int
  signingKeyId       String
  signingIssuer      String
  signingSubject     String
  issuedAt           DateTime
  registeredById     String
  lastVerifiedById   String
  registeredAt       DateTime @default(now())
  verifiedAt         DateTime @default(now())

  registeredBy   User                        @relation("passportRegistrant", fields: [registeredById], references: [id])
  lastVerifiedBy User                        @relation("passportVerifier", fields: [lastVerifiedById], references: [id])
  claims         ExecutionPassportClaim[]
  artifacts      ExecutionPassportArtifact[]

  @@index([verificationStatus, registeredAt])
  @@index([commitSha])
}

model ExecutionPassportClaim {
  id         String @id @default(cuid())
  passportId String
  claimId    String

  passport ExecutionPassport @relation(fields: [passportId], references: [id])
  claim    Claim             @relation(fields: [claimId], references: [id])

  @@unique([passportId, claimId])
  @@index([claimId])
}

model ExecutionPassportArtifact {
  id         String  @id @default(cuid())
  passportId String
  entityId   String
  /// input | output
  role       String
  name       String
  path       String
  mediaType  String?
  byteSize   Int
  sha256     String

  passport ExecutionPassport @relation(fields: [passportId], references: [id])

  @@unique([passportId, entityId])
  @@index([passportId, role])
}

model Citation {
  id              String  @id @default(cuid())
  reviewVersionId String
  localCitationId String
  doi             String?
  pmid            String?
  openAlexId      String?
  title           String?
  authorsJson     String  @default("[]")
  year            Int?
  source          String?
  url             String?
  /// Declared dataset/cohort accessions (JSON string array) and derivative
  /// source DOIs (JSON string array): deterministic independence signals.
  datasetIdsJson  String  @default("[]")
  derivedFromJson String  @default("[]")
  rawCitationJson String?

  reviewVersion     ReviewVersion           @relation(fields: [reviewVersionId], references: [id])
  evidenceRelations ClaimEvidenceRelation[]
  updateProposals   ClaimUpdateProposal[]

  @@unique([reviewVersionId, localCitationId])
  @@index([doi])
}

model ClaimEvidenceRelation {
  id                   String  @id @default(cuid())
  claimId              String
  citationId           String
  /// contracts CLAIM_EVIDENCE_RELATION_TYPES
  relationType         String
  supportDirection     String?
  sourceLocation       String?
  extractionMethod     String?
  extractionConfidence Float?
  humanReviewed        Boolean @default(false)

  claim            Claim             @relation(fields: [claimId], references: [id])
  citation         Citation          @relation(fields: [citationId], references: [id])
  trustAssessments TrustAssessment[]

  @@unique([claimId, citationId, relationType])
}

/// TRUST attaches to a claim–citation relation, never to a citation globally.
/// Criterion-level records are authoritative; the aggregate is optional and
/// must carry the algorithm/version that produced it.
model TrustAssessment {
  id                      String    @id @default(cuid())
  claimEvidenceRelationId String
  protocolVersion         String
  /// agent | human
  assessorType            String
  assessorId              String?
  assessedAt              DateTime?

  /// Each criterion: JSON {rating, status, rationale, evidencePointer} — the
  /// column stays queryable per criterion while remaining provider-portable.
  identityIntegrity             String?
  entailment                    String?
  sourceAccess                  String?
  populationRelevance           String?
  interventionExposureRelevance String?
  outcomeRelevance              String?
  methodologicalSafeguards      String?
  statisticalSafeguards         String?
  replicationConvergence        String?
  conflictDependency            String?

  limitationsJson String    @default("[]")
  evidenceJson    String?
  aggregateScore  Float?
  aggregateMethod String?
  /// Public imported state is always unverified-import. A valid separate
  /// TrustVerification marker can elevate it at read time.
  reviewStatus    String    @default("unverified-import")
  adjudicatorId   String?
  adjudicatedAt   DateTime?

  /// Exact repository assertions are provenance only, never platform trust.
  /// sourceRecordJson preserves absent versus explicit-null source fields.
  sourceRecordJson            String?
  sourceReviewStatus          String?
  sourceAssessorType          String?
  sourceAssessorId            String?
  sourceAssessedAt            DateTime?
  sourceEvidenceJson          String?
  sourceAggregateScore        Float?
  sourceAggregateMethod       String?
  sourceRelationHumanReviewed Boolean?

  /// Incremented by editorial verification writes for optimistic concurrency.
  revision  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  relation     ClaimEvidenceRelation @relation(fields: [claimEvidenceRelationId], references: [id])
  verification TrustVerification?

  @@index([reviewStatus])
}

/// Platform-owned review marker. This is deliberately separate from the
/// repository-authored TRUST assessment and relation assertions.
model TrustVerification {
  id                   String   @id @default(cuid())
  trustAssessmentId    String   @unique
  /// human-reviewed | adjudicated
  status               String
  reviewerId           String
  reviewerRoleSnapshot String
  rationale            String
  /// SHA-256 over the canonical reviewed subject. Reads fail closed on mismatch.
  assessmentHash       String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  assessment TrustAssessment @relation(fields: [trustAssessmentId], references: [id])
  reviewer   User            @relation("trustReviewer", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([reviewerId])
}

/// Imported TRUST assessment whose mandatory subject is one exact immutable
/// author node-edge proposal. The proposal survives editorial rejection and
/// links to the confirmed edge when accepted, preserving the imported subject.
model NodeRelationTrustAssessment {
  id                 String    @id @default(cuid())
  nodeEdgeProposalId String
  protocolVersion    String
  assessorType       String
  assessorId         String?
  assessedAt         DateTime?

  identityIntegrity             String?
  entailment                    String?
  sourceAccess                  String?
  populationRelevance           String?
  interventionExposureRelevance String?
  outcomeRelevance              String?
  methodologicalSafeguards      String?
  statisticalSafeguards         String?
  replicationConvergence        String?
  conflictDependency            String?

  limitationsJson String  @default("[]")
  evidenceJson    String?
  aggregateScore  Float?
  aggregateMethod String?
  reviewStatus    String  @default("unverified-import")

  /// Exact strict parsed repository record, including the relation subject.
  sourceRecordJson      String
  sourceReviewStatus    String
  sourceAssessorType    String
  sourceAssessorId      String?
  sourceAssessedAt      DateTime?
  sourceEvidenceJson    String?
  sourceAggregateScore  Float?
  sourceAggregateMethod String?

  revision  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposal     NodeEdgeProposal               @relation(fields: [nodeEdgeProposalId], references: [id])
  verification NodeRelationTrustVerification?

  @@index([nodeEdgeProposalId])
  @@index([reviewStatus])
}

/// Platform marker for a node-relation assessment. Kept separate from legacy
/// claim-citation verification so neither subject can exist without its FK.
model NodeRelationTrustVerification {
  id                            String   @id @default(cuid())
  nodeRelationTrustAssessmentId String   @unique
  status                        String
  reviewerId                    String
  reviewerRoleSnapshot          String
  rationale                     String
  assessmentHash                String
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  assessment NodeRelationTrustAssessment @relation(fields: [nodeRelationTrustAssessmentId], references: [id])
  reviewer   User                        @relation("nodeRelationTrustReviewer", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([reviewerId])
}

model AgentRun {
  id                  String    @id @default(cuid())
  /// e.g. "discussion-answer", "link-proposal", "llm-extraction"
  agentType           String
  modelProvider       String?
  modelName           String?
  modelVersion        String?
  promptVersion       String?
  promptHash          String?
  packetHash          String?
  inputHash           String?
  inputReferencesJson String?
  outputJson          String?
  /// running | succeeded | failed
  status              String
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  error               String?
  /// unreviewed | approved | rejected
  humanReviewStatus   String    @default("unreviewed")

  discussionMessages DiscussionMessage[]
  nodeEdgeProposals  NodeEdgeProposal[]
}

model DiscussionThread {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  /// JSON: review slugs / filters bounding the thread.
  scopeJson String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?               @relation(fields: [userId], references: [id])
  messages DiscussionMessage[]
}

model DiscussionMessage {
  id                String   @id @default(cuid())
  threadId          String
  /// user | assistant
  role              String
  content           String
  /// Evidence packet reference + grounding validation result.
  groundingJson     String?
  modelMetadataJson String?
  agentRunId        String?
  createdAt         DateTime @default(now())

  thread   DiscussionThread @relation(fields: [threadId], references: [id])
  agentRun AgentRun?        @relation(fields: [agentRunId], references: [id])
}

/// Human peer commentary on a published review — the scholarly exchange layer.
/// Distinct from DiscussionThread/Message, which persist AI-grounded Q&A.
/// Bodies are plain text only and always rendered escaped (never raw HTML).
model ReviewComment {
  id              String    @id @default(cuid())
  reviewId        String
  /// Immutable review version this comment was made against. Nullable only
  /// for legacy rows created before version-scoped discussion.
  reviewVersionId String?
  authorId        String
  /// Top-level comment when null; threads are one level deep (replies).
  parentId        String?
  /// Optional claim this comment is anchored to (claim-level commentary).
  claimId         String?
  /// contracts COMMENT_KINDS: comment | question | concern | suggestion | endorsement
  kind            String    @default("comment")
  body            String
  /// contracts COMMENT_STATUSES: visible | removed
  status          String    @default("visible")
  /// User id of the remover (author or editor); no FK to keep moderation light.
  removedById     String?
  removedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  review        Review          @relation(fields: [reviewId], references: [id])
  reviewVersion ReviewVersion?  @relation(fields: [reviewVersionId], references: [id])
  author        User            @relation(fields: [authorId], references: [id])
  parent        ReviewComment?  @relation("replies", fields: [parentId], references: [id])
  replies       ReviewComment[] @relation("replies")
  claim         Claim?          @relation(fields: [claimId], references: [id])

  @@index([reviewId, createdAt])
  @@index([reviewVersionId, createdAt])
}

/// Conservative automated cross-review link proposals (spec §15).
model KnowledgeLinkProposal {
  id                 String    @id @default(cuid())
  sourceClaimId      String
  targetClaimId      String
  /// contracts LINK_PROPOSAL_TYPES
  proposedRelation   String
  /// Deterministic features that produced the proposal (shared DOIs, token overlap...).
  featuresJson       String
  semanticSimilarity Float?
  rationale          String
  /// Provenance: agent run / extractor version.
  agentProvenance    String
  /// proposed | accepted | rejected | superseded
  status             String    @default("proposed")
  reviewedById       String?
  reviewedAt         DateTime?
  createdAt          DateTime  @default(now())

  sourceClaim Claim @relation("sourceClaim", fields: [sourceClaimId], references: [id])
  targetClaim Claim @relation("targetClaim", fields: [targetClaimId], references: [id])

  @@unique([sourceClaimId, targetClaimId, proposedRelation])
}

/// Append-only audit trail for editorially meaningful changes.
model AuditEvent {
  id             String   @id @default(cuid())
  actorId        String?
  /// e.g. submission.finalized, submission.accepted, review.published,
  /// trust.adjudicated, linkProposal.reviewed, auth.mock-login-refused
  action         String
  subjectType    String
  subjectId      String
  detailsJson    String   @default("{}")
  /// Optional deterministic key for retry-safe transactional events.
  idempotencyKey String?
  createdAt      DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([subjectType, subjectId])
  @@index([idempotencyKey])
}

/// Database-enforced operation claim used before retry-safe audit writes.
/// A new table keeps populated upgrades safe without adding a unique index
/// over a legacy nullable column.
model IdempotencyKey {
  key       String   @id
  createdAt DateTime @default(now())
}

/// Editor responsible for a submission, with an explicit conflict-of-interest
/// declaration. A declared conflict forces immediate recusal; an editor can
/// never be assigned to their own submission.
model EditorAssignment {
  id           String   @id @default(cuid())
  submissionId String
  editorId     String
  assignedById String
  /// contracts EDITOR_ASSIGNMENT_STATUSES: active | recused | completed
  status       String   @default("active")
  coiDeclared  Boolean  @default(false)
  coiStatement String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id])
  editor     User       @relation("assignmentEditor", fields: [editorId], references: [id])
  assignedBy User       @relation("assignmentAssigner", fields: [assignedById], references: [id])

  @@unique([submissionId, editorId])
}

/// Numbered formal review round on a submission. Rounds are append-only and
/// close exactly once with a decision letter.
model ReviewRound {
  id           String    @id @default(cuid())
  submissionId String
  roundNumber  Int
  /// contracts REVIEW_ROUND_STATUSES: open | decided
  status       String    @default("open")
  openedById   String
  openedAt     DateTime  @default(now())
  decidedAt    DateTime?

  submission     Submission           @relation(fields: [submissionId], references: [id])
  openedBy       User                 @relation("roundOpener", fields: [openedById], references: [id])
  reports        FormalReviewReport[]
  responses      AuthorResponse[]
  decisionLetter DecisionLetter?

  @@unique([submissionId, roundNumber])
}

/// Immutable, attributable formal peer-review report. One report per
/// reviewer per round; there is no update or delete path.
model FormalReviewReport {
  id                    String   @id @default(cuid())
  roundId               String
  reviewerId            String
  /// Reviewer ORCID snapshot at submission time (contracts orcidSchema).
  reviewerOrcid         String?
  reviewerOrcidVerified Boolean  @default(false)
  /// contracts REVIEW_RECOMMENDATIONS
  recommendation        String
  /// Canonical JSON of contracts formalReviewReportBodySchema.
  bodyJson              String
  /// SHA-256 of bodyJson (integrity of the immutable report).
  bodyHash              String
  coiStatement          String?
  submittedAt           DateTime @default(now())

  round    ReviewRound @relation(fields: [roundId], references: [id])
  reviewer User        @relation("formalReviewer", fields: [reviewerId], references: [id])

  @@unique([roundId, reviewerId])
}

/// Author response within a review round; append-only and attributable.
model AuthorResponse {
  id          String   @id @default(cuid())
  roundId     String
  authorId    String
  /// Canonical JSON of contracts authorResponseBodySchema.
  bodyJson    String
  bodyHash    String
  submittedAt DateTime @default(now())

  round  ReviewRound @relation(fields: [roundId], references: [id])
  author User        @relation("respondingAuthor", fields: [authorId], references: [id])
}

/// Decision letter closing a round. Exactly one per round; immutable.
model DecisionLetter {
  id        String   @id @default(cuid())
  roundId   String   @unique
  editorId  String
  /// contracts ROUND_DECISIONS: accept | reject | request-changes
  decision  String
  /// Canonical JSON of contracts decisionLetterBodySchema.
  bodyJson  String
  bodyHash  String
  createdAt DateTime @default(now())

  round  ReviewRound @relation(fields: [roundId], references: [id])
  editor User        @relation("decisionEditor", fields: [editorId], references: [id])
}

/// In-app notification for editorial lifecycle events.
model Notification {
  id          String    @id @default(cuid())
  userId      String
  /// contracts NOTIFICATION_KINDS
  kind        String
  subjectType String
  subjectId   String
  payloadJson String    @default("{}")
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation("notificationUser", fields: [userId], references: [id])

  @@index([userId, readAt])
}

/// Externally observed change to a cited work (retraction, correction,
/// expression of concern, new evidence). Signals are append-only.
model CitationStatusRecord {
  id           String   @id @default(cuid())
  /// Canonical work alias (contracts canonicalWorkAliases form, e.g. doi:10.x/y).
  workAlias    String
  /// contracts CITATION_STATUSES
  status       String
  /// Where the signal came from (registry, publisher notice, manual review).
  source       String
  evidenceUrl  String?
  note         String?
  recordedById String?
  recordedAt   DateTime @default(now())

  recordedBy User?                 @relation("statusRecorder", fields: [recordedById], references: [id])
  proposals  ClaimUpdateProposal[]

  @@index([workAlias])
}

/// Human-reviewable update proposal opened when a status signal affects a
/// claim. Conclusions are never rewritten automatically; an editor resolves
/// each proposal with an attributable note.
model ClaimUpdateProposal {
  id             String    @id @default(cuid())
  statusRecordId String
  claimId        String
  citationId     String
  /// contracts PROPOSAL_STATUSES
  status         String    @default("open")
  /// Deterministic description of why this claim is affected.
  rationale      String
  resolvedById   String?
  resolutionNote String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  statusRecord CitationStatusRecord @relation(fields: [statusRecordId], references: [id])
  claim        Claim                @relation(fields: [claimId], references: [id])
  citation     Citation             @relation(fields: [citationId], references: [id])
  resolvedBy   User?                @relation("proposalResolver", fields: [resolvedById], references: [id])

  @@unique([statusRecordId, claimId])
  @@index([status])
}

/// COAR Notify review activities received from or prepared for external
/// repository services. Payloads are immutable canonical JSON; an editor may
/// accept or reject an inbound request, but never rewrite the received bytes.
model FederationNotification {
  id              String    @id @default(cuid())
  activityId      String    @unique
  /// inbound | outbound
  direction       String
  /// request-review | announce-review
  pattern         String
  /// pending | accepted | rejected | prepared | delivered
  status          String    @default("pending")
  actorUri        String?
  objectUri       String
  contextUri      String?
  originUri       String
  originInbox     String?
  targetUri       String
  targetInbox     String
  inReplyTo       String?
  payloadJson     String
  payloadHash     String
  reviewVersionId String?
  resolvedById    String?
  resolutionNote  String?
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  reviewVersion ReviewVersion? @relation(fields: [reviewVersionId], references: [id])
  resolvedBy    User?          @relation("federationResolver", fields: [resolvedById], references: [id])

  @@index([direction, status, createdAt])
  @@index([reviewVersionId])
  @@index([inReplyTo])
}

/// Immutable registry payload plus its deterministic normalized representation.
/// The primary key is a SHA-256-derived stable id over the exact target, source
/// version and payload hash, making retries idempotent across SQLite/PostgreSQL.
model ProtocolSnapshot {
  id                   String    @id
  reviewVersionId      String
  claimId              String?
  createdById          String
  /// review-version:<id> or claim:<id>; explicit because nullable unique keys
  /// behave differently between providers.
  targetKey            String
  /// osf | clinicaltrials-gov
  registry             String
  sourceId             String
  sourceUrl            String
  sourceVersion        String
  sourceTimestamp      DateTime?
  fetchedAt            DateTime
  normalizedJson       String
  rawJson              String
  questionMetadataJson String?
  contentHash          String
  observedJson         String
  comparatorVersion    String
  createdAt            DateTime  @default(now())

  reviewVersion ReviewVersion           @relation(fields: [reviewVersionId], references: [id])
  claim         Claim?                  @relation(fields: [claimId], references: [id])
  createdBy     User                    @relation("protocolSnapshotCreator", fields: [createdById], references: [id])
  proposals     ProtocolDriftProposal[]

  @@unique([targetKey, registry, sourceId, sourceVersion])
  @@index([reviewVersionId, createdAt])
  @@index([claimId, createdAt])
  @@index([registry, sourceId])
}

/// Neutral, human-reviewable reconciliation proposal. It never asserts intent
/// or rewrites review content. Stable comparison ids make creation retry-safe.
model ProtocolDriftProposal {
  id                String    @id
  snapshotId        String
  /// population | outcomes | exclusions | analysis-plan
  category          String
  /// not-described-in-review | not-registered | content-differs
  kind              String
  registeredJson    String
  observedJson      String
  rationale         String
  comparatorVersion String
  /// open | confirmed-update-needed | explained | dismissed
  status            String    @default("open")
  resolvedById      String?
  resolutionNote    String?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())

  snapshot   ProtocolSnapshot @relation(fields: [snapshotId], references: [id])
  resolvedBy User?            @relation("protocolProposalResolver", fields: [resolvedById], references: [id])

  @@index([snapshotId, status])
  @@index([status, createdAt])
}
