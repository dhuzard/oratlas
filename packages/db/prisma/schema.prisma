// Open Review Atlas — core data model (spec §9).
//
// SQLite for zero-configuration local development; the schema deliberately
// avoids SQLite-only and Postgres-only features so switching the datasource
// provider to "postgresql" is a configuration change:
//   - enums are String columns validated by @oratlas/contracts at the app layer
//   - JSON payloads are String columns containing JSON ("...Json" suffix)
//   - arrays (topics, roles, keywords) are JSON-encoded String columns
generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String   @id @default(cuid())
  githubUserId          String?  @unique
  githubLogin           String   @unique
  /// NFKC + lowercase login used solely for collision prevention.
  /// Transitional: application-enforced uniqueness until issue #7.
  githubLoginNormalized String?
  displayName           String?
  avatarUrl             String?
  profileUrl            String?
  /// USER | EDITOR | ADMIN
  role                  String   @default("USER")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  submissions        Submission[]        @relation("submitter")
  editorialDecisions Submission[]        @relation("reviewer")
  discussionThreads  DiscussionThread[]
  reviewComments     ReviewComment[]
  auditEvents        AuditEvent[]
  trustVerifications TrustVerification[] @relation("trustReviewer")

  @@index([githubLoginNormalized])
}

model Repository {
  id                 String    @id @default(cuid())
  /// Always "github.com" in the POC.
  host               String    @default("github.com")
  owner              String
  name               String
  canonicalUrl       String    @unique
  githubRepositoryId Int?
  defaultBranch      String?
  description        String?
  licenseSpdx        String?
  /// JSON array of topic strings.
  topicsJson         String    @default("[]")
  homepageUrl        String?
  pagesUrl           String?
  isArchived         Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastInspectedAt    DateTime?

  snapshots   RepositorySnapshot[]
  submissions Submission[]

  @@unique([host, owner, name])
}

model RepositorySnapshot {
  id                   String    @id @default(cuid())
  repositoryId         String
  commitSha            String
  branch               String?
  releaseTag           String?
  releaseUrl           String?
  /// When the commit/release was created on GitHub.
  sourceCreatedAt      DateTime?
  capturedAt           DateTime  @default(now())
  /// succeeded | partial | failed
  inspectionStatus     String
  inspectionReportJson String
  /// Validated review manifest content, when present.
  manifestJson         String?
  /// SHA-256 over the normalized inspection payload (integrity/versioning aid).
  contentHash          String

  repository     Repository      @relation(fields: [repositoryId], references: [id])
  submissions    Submission[]
  reviewVersions ReviewVersion[]
  currentOf      Review[]        @relation("currentSnapshot")

  @@unique([repositoryId, commitSha])
}

model Review {
  id                 String    @id @default(cuid())
  slug               String    @unique
  currentSnapshotId  String?
  title              String
  abstract           String?
  /// contracts REVIEW_TYPES
  reviewType         String?
  licenseSpdx        String?
  publishedReviewUrl String?
  /// published | withdrawn | superseded
  status             String    @default("published")
  acceptedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  currentSnapshot RepositorySnapshot? @relation("currentSnapshot", fields: [currentSnapshotId], references: [id])
  versions        ReviewVersion[]
  comments        ReviewComment[]
}

model ReviewVersion {
  id              String    @id @default(cuid())
  reviewId        String
  snapshotId      String
  semanticVersion String?
  title           String
  abstract        String?
  /// Effective metadata + provenance for this immutable version.
  metadataJson    String
  versionDoi      String?
  conceptDoi      String?
  zenodoRecordId  String?
  releaseTag      String?
  /// True when every DOI/identifier on this version is a synthetic example
  /// (seed/demo data). The UI must not render outbound resolvers for these.
  isExample       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())

  review       Review              @relation(fields: [reviewId], references: [id])
  snapshot     RepositorySnapshot  @relation(fields: [snapshotId], references: [id])
  contributors ReviewContributor[]
  identifiers  Identifier[]
  claims       Claim[]
  citations    Citation[]
}

model Person {
  id          String  @id @default(cuid())
  displayName String
  givenName   String?
  familyName  String?
  orcid       String?
  githubLogin String?

  contributions ReviewContributor[]
}

model ReviewContributor {
  reviewVersionId String
  personId        String
  /// JSON array of role strings (e.g. ["author"], ["maintainer"]).
  rolesJson       String @default("[]")
  position        Int

  reviewVersion ReviewVersion @relation(fields: [reviewVersionId], references: [id])
  person        Person        @relation(fields: [personId], references: [id])

  @@id([reviewVersionId, personId])
}

model Submission {
  id                    String    @id @default(cuid())
  submitterId           String
  repositoryId          String
  snapshotId            String?
  /// contracts SUBMISSION_STATUSES
  status                String    @default("draft")
  extractedMetadataJson String?
  editedMetadataJson    String?
  validationReportJson  String?
  /// Immutable snapshot of the exact payload the submitter finalized.
  submittedPayloadJson  String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  reviewerId            String?
  editorialNote         String?
  /// Review created/updated when this submission was accepted.
  resultingReviewId     String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  submitter  User                @relation("submitter", fields: [submitterId], references: [id])
  reviewer   User?               @relation("reviewer", fields: [reviewerId], references: [id])
  repository Repository          @relation(fields: [repositoryId], references: [id])
  snapshot   RepositorySnapshot? @relation(fields: [snapshotId], references: [id])
}

model Identifier {
  id                   String  @id @default(cuid())
  reviewVersionId      String
  /// doi | github | orcid | url | zenodo-record
  scheme               String
  value                String
  normalizedValue      String
  url                  String?
  /// version-doi | concept-doi | repository | release | published-review | zenodo-record | author-orcid
  relationType         String
  /// unvalidated | valid | valid-with-warnings | invalid | example-not-resolvable
  validationStatus     String  @default("unvalidated")
  validationReportJson String?
  /// Synthetic example identifier — never render as an outbound link.
  isExample            Boolean @default(false)

  reviewVersion ReviewVersion @relation(fields: [reviewVersionId], references: [id])

  @@index([scheme, normalizedValue])
}

model Claim {
  id              String   @id @default(cuid())
  reviewVersionId String
  /// Identifier within the source repository artifacts (e.g. "claim-003").
  localClaimId    String
  text            String
  normalizedText  String
  section         String?
  anchor          String?
  /// contracts CLAIM_TYPES
  claimType       String?
  qualification   String?
  createdAt       DateTime @default(now())

  reviewVersion     ReviewVersion           @relation(fields: [reviewVersionId], references: [id])
  evidenceRelations ClaimEvidenceRelation[]
  linkProposalsFrom KnowledgeLinkProposal[] @relation("sourceClaim")
  linkProposalsTo   KnowledgeLinkProposal[] @relation("targetClaim")
  comments          ReviewComment[]

  @@unique([reviewVersionId, localClaimId])
}

model Citation {
  id              String  @id @default(cuid())
  reviewVersionId String
  localCitationId String
  doi             String?
  pmid            String?
  openAlexId      String?
  title           String?
  authorsJson     String  @default("[]")
  year            Int?
  source          String?
  url             String?
  rawCitationJson String?

  reviewVersion     ReviewVersion           @relation(fields: [reviewVersionId], references: [id])
  evidenceRelations ClaimEvidenceRelation[]

  @@unique([reviewVersionId, localCitationId])
  @@index([doi])
}

model ClaimEvidenceRelation {
  id                   String  @id @default(cuid())
  claimId              String
  citationId           String
  /// contracts CLAIM_EVIDENCE_RELATION_TYPES
  relationType         String
  supportDirection     String?
  sourceLocation       String?
  extractionMethod     String?
  extractionConfidence Float?
  humanReviewed        Boolean @default(false)

  claim            Claim             @relation(fields: [claimId], references: [id])
  citation         Citation          @relation(fields: [citationId], references: [id])
  trustAssessments TrustAssessment[]

  @@unique([claimId, citationId, relationType])
}

/// TRUST attaches to a claim–citation relation, never to a citation globally.
/// Criterion-level records are authoritative; the aggregate is optional and
/// must carry the algorithm/version that produced it.
model TrustAssessment {
  id                      String    @id @default(cuid())
  claimEvidenceRelationId String
  protocolVersion         String
  /// agent | human
  assessorType            String
  assessorId              String?
  assessedAt              DateTime?

  /// Each criterion: JSON {rating, status, rationale, evidencePointer} — the
  /// column stays queryable per criterion while remaining provider-portable.
  identityIntegrity             String?
  entailment                    String?
  sourceAccess                  String?
  populationRelevance           String?
  interventionExposureRelevance String?
  outcomeRelevance              String?
  methodologicalSafeguards      String?
  statisticalSafeguards         String?
  replicationConvergence        String?
  conflictDependency            String?

  limitationsJson String    @default("[]")
  evidenceJson    String?
  aggregateScore  Float?
  aggregateMethod String?
  /// Public imported state is always unverified-import. A valid separate
  /// TrustVerification marker can elevate it at read time.
  reviewStatus    String    @default("unverified-import")
  adjudicatorId   String?
  adjudicatedAt   DateTime?

  /// Exact repository assertions are provenance only, never platform trust.
  /// sourceRecordJson preserves absent versus explicit-null source fields.
  sourceRecordJson            String?
  sourceReviewStatus          String?
  sourceAssessorType          String?
  sourceAssessorId            String?
  sourceAssessedAt            DateTime?
  sourceEvidenceJson          String?
  sourceAggregateScore        Float?
  sourceAggregateMethod       String?
  sourceRelationHumanReviewed Boolean?

  /// Incremented by editorial verification writes for optimistic concurrency.
  revision  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  relation     ClaimEvidenceRelation @relation(fields: [claimEvidenceRelationId], references: [id])
  verification TrustVerification?

  @@index([reviewStatus])
}

/// Platform-owned review marker. This is deliberately separate from the
/// repository-authored TRUST assessment and relation assertions.
model TrustVerification {
  id                   String   @id @default(cuid())
  trustAssessmentId    String   @unique
  /// human-reviewed | adjudicated
  status               String
  reviewerId           String
  reviewerRoleSnapshot String
  rationale            String
  /// SHA-256 over the canonical reviewed subject. Reads fail closed on mismatch.
  assessmentHash       String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  assessment TrustAssessment @relation(fields: [trustAssessmentId], references: [id])
  reviewer   User            @relation("trustReviewer", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([reviewerId])
}

model AgentRun {
  id                  String    @id @default(cuid())
  /// e.g. "discussion-answer", "link-proposal", "llm-extraction"
  agentType           String
  modelProvider       String?
  modelName           String?
  modelVersion        String?
  promptVersion       String?
  inputHash           String?
  inputReferencesJson String?
  outputJson          String?
  /// running | succeeded | failed
  status              String
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  error               String?
  /// unreviewed | approved | rejected
  humanReviewStatus   String    @default("unreviewed")

  discussionMessages DiscussionMessage[]
}

model DiscussionThread {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  /// JSON: review slugs / filters bounding the thread.
  scopeJson String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?               @relation(fields: [userId], references: [id])
  messages DiscussionMessage[]
}

model DiscussionMessage {
  id                String   @id @default(cuid())
  threadId          String
  /// user | assistant
  role              String
  content           String
  /// Evidence packet reference + grounding validation result.
  groundingJson     String?
  modelMetadataJson String?
  agentRunId        String?
  createdAt         DateTime @default(now())

  thread   DiscussionThread @relation(fields: [threadId], references: [id])
  agentRun AgentRun?        @relation(fields: [agentRunId], references: [id])
}

/// Human peer commentary on a published review — the scholarly exchange layer.
/// Distinct from DiscussionThread/Message, which persist AI-grounded Q&A.
/// Bodies are plain text only and always rendered escaped (never raw HTML).
model ReviewComment {
  id          String    @id @default(cuid())
  reviewId    String
  authorId    String
  /// Top-level comment when null; threads are one level deep (replies).
  parentId    String?
  /// Optional claim this comment is anchored to (claim-level commentary).
  claimId     String?
  /// contracts COMMENT_KINDS: comment | question | concern | suggestion | endorsement
  kind        String    @default("comment")
  body        String
  /// contracts COMMENT_STATUSES: visible | removed
  status      String    @default("visible")
  /// User id of the remover (author or editor); no FK to keep moderation light.
  removedById String?
  removedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  review  Review          @relation(fields: [reviewId], references: [id])
  author  User            @relation(fields: [authorId], references: [id])
  parent  ReviewComment?  @relation("replies", fields: [parentId], references: [id])
  replies ReviewComment[] @relation("replies")
  claim   Claim?          @relation(fields: [claimId], references: [id])

  @@index([reviewId, createdAt])
}

/// Conservative automated cross-review link proposals (spec §15).
model KnowledgeLinkProposal {
  id                 String    @id @default(cuid())
  sourceClaimId      String
  targetClaimId      String
  /// contracts LINK_PROPOSAL_TYPES
  proposedRelation   String
  /// Deterministic features that produced the proposal (shared DOIs, token overlap...).
  featuresJson       String
  semanticSimilarity Float?
  rationale          String
  /// Provenance: agent run / extractor version.
  agentProvenance    String
  /// proposed | accepted | rejected | superseded
  status             String    @default("proposed")
  reviewedById       String?
  reviewedAt         DateTime?
  createdAt          DateTime  @default(now())

  sourceClaim Claim @relation("sourceClaim", fields: [sourceClaimId], references: [id])
  targetClaim Claim @relation("targetClaim", fields: [targetClaimId], references: [id])

  @@unique([sourceClaimId, targetClaimId, proposedRelation])
}

/// Append-only audit trail for editorially meaningful changes.
model AuditEvent {
  id          String   @id @default(cuid())
  actorId     String?
  /// e.g. submission.finalized, submission.accepted, review.published,
  /// trust.adjudicated, linkProposal.reviewed, auth.mock-login-refused
  action      String
  subjectType String
  subjectId   String
  detailsJson String   @default("{}")
  createdAt   DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([subjectType, subjectId])
}
