  @@unique([claimId, citationId, relationType])
}

/// TRUST attaches to a claim–citation relation, never to a citation globally.
/// Criterion-level records are authoritative; the aggregate is optional and
/// must carry the algorithm/version that produced it.
model TrustAssessment {
  id                      String    @id @default(cuid())
  claimEvidenceRelationId String
  protocolVersion         String
  /// agent | human
  assessorType            String
  assessorId              String?
  assessedAt              DateTime?

  /// Each criterion: JSON {rating, status, rationale, evidencePointer} — the
  /// column stays queryable per criterion while remaining provider-portable.
  identityIntegrity             String?
  entailment                    String?
  sourceAccess                  String?
  populationRelevance           String?
  interventionExposureRelevance String?
  outcomeRelevance              String?
  methodologicalSafeguards      String?
  statisticalSafeguards         String?
  replicationConvergence        String?
  conflictDependency            String?

  limitationsJson String    @default("[]")
  evidenceJson    String?
  aggregateScore  Float?
  aggregateMethod String?
  /// Public imported state is always unverified-import. A valid separate
  /// TrustVerification marker can elevate it at read time.
  reviewStatus    String    @default("unverified-import")
  adjudicatorId   String?
  adjudicatedAt   DateTime?

  /// Exact repository assertions are provenance only, never platform trust.
  /// sourceRecordJson preserves absent versus explicit-null source fields.
  sourceRecordJson            String?
  sourceReviewStatus          String?
  sourceAssessorType          String?
  sourceAssessorId            String?
  sourceAssessedAt            DateTime?
  sourceEvidenceJson          String?
  sourceAggregateScore        Float?
  sourceAggregateMethod       String?
  sourceRelationHumanReviewed Boolean?

  /// Incremented by editorial verification writes for optimistic concurrency.
  revision  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  relation     ClaimEvidenceRelation @relation(fields: [claimEvidenceRelationId], references: [id])
  verification TrustVerification?

  @@index([reviewStatus])
}

/// Platform-owned review marker. This is deliberately separate from the
/// repository-authored TRUST assessment and relation assertions.
model TrustVerification {
  id                   String   @id @default(cuid())
  trustAssessmentId    String   @unique
  /// human-reviewed | adjudicated
  status               String
  reviewerId           String
  reviewerRoleSnapshot String
  rationale            String
  /// SHA-256 over the canonical reviewed subject. Reads fail closed on mismatch.
  assessmentHash       String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  assessment TrustAssessment @relation(fields: [trustAssessmentId], references: [id])
  reviewer   User            @relation("trustReviewer", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([reviewerId])
}

