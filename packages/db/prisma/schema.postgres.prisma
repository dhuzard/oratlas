  reviewerOrcidVerified Boolean  @default(false)
  /// contracts REVIEW_RECOMMENDATIONS
  recommendation        String
  /// Canonical JSON of contracts formalReviewReportBodySchema.
  bodyJson              String
  /// SHA-256 of bodyJson (integrity of the immutable report).
  bodyHash              String
  coiStatement          String?
  submittedAt           DateTime @default(now())

  round    ReviewRound @relation(fields: [roundId], references: [id])
  reviewer User        @relation("formalReviewer", fields: [reviewerId], references: [id])

  @@unique([roundId, reviewerId])
}

/// Author response within a review round; append-only and attributable.
model AuthorResponse {
  id          String   @id @default(cuid())
  roundId     String
  authorId    String
  /// Canonical JSON of contracts authorResponseBodySchema.
  bodyJson    String
  bodyHash    String
  submittedAt DateTime @default(now())

  round  ReviewRound @relation(fields: [roundId], references: [id])
  author User        @relation("respondingAuthor", fields: [authorId], references: [id])
}

/// Decision letter closing a round. Exactly one per round; immutable.
model DecisionLetter {
  id        String   @id @default(cuid())
  roundId   String   @unique
  editorId  String
  /// contracts ROUND_DECISIONS: accept | reject | request-changes
  decision  String
  /// Canonical JSON of contracts decisionLetterBodySchema.
  bodyJson  String
  bodyHash  String
  createdAt DateTime @default(now())

  round  ReviewRound @relation(fields: [roundId], references: [id])
  editor User        @relation("decisionEditor", fields: [editorId], references: [id])
}

/// In-app notification for editorial lifecycle events.
model Notification {
  id          String    @id @default(cuid())
  userId      String
  /// contracts NOTIFICATION_KINDS
  kind        String
  subjectType String
  subjectId   String
  payloadJson String    @default("{}")
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  user User @relation("notificationUser", fields: [userId], references: [id])

  @@index([userId, readAt])
}

/// Externally observed change to a cited work (retraction, correction,
/// expression of concern, new evidence). Signals are append-only.
model CitationStatusRecord {
  id           String   @id @default(cuid())
  /// Canonical work alias (contracts canonicalWorkAliases form, e.g. doi:10.x/y).
  workAlias    String
  /// contracts CITATION_STATUSES
  status       String
  /// Where the signal came from (registry, publisher notice, manual review).
  source       String
  evidenceUrl  String?
  note         String?
  recordedById String?
  recordedAt   DateTime @default(now())

  recordedBy User?                 @relation("statusRecorder", fields: [recordedById], references: [id])
  proposals  ClaimUpdateProposal[]

  @@index([workAlias])
}

/// Human-reviewable update proposal opened when a status signal affects a
/// claim. Conclusions are never rewritten automatically; an editor resolves
/// each proposal with an attributable note.
model ClaimUpdateProposal {
  id             String    @id @default(cuid())
  statusRecordId String
  claimId        String
  citationId     String
  /// contracts PROPOSAL_STATUSES
  status         String    @default("open")
  /// Deterministic description of why this claim is affected.
  rationale      String
  resolvedById   String?
  resolutionNote String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  statusRecord CitationStatusRecord @relation(fields: [statusRecordId], references: [id])
  claim        Claim                @relation(fields: [claimId], references: [id])
  citation     Citation             @relation(fields: [citationId], references: [id])
  resolvedBy   User?                @relation("proposalResolver", fields: [resolvedById], references: [id])

  @@unique([statusRecordId, claimId])
  @@index([status])
}

/// COAR Notify review activities received from or prepared for external
/// repository services. Payloads are immutable canonical JSON; an editor may
/// accept or reject an inbound request, but never rewrite the received bytes.
model FederationNotification {
  id              String    @id @default(cuid())
  activityId      String    @unique
  /// inbound | outbound
  direction       String
  /// request-review | announce-review
  pattern         String
  /// pending | accepted | rejected | prepared | delivered
  status          String    @default("pending")
  actorUri        String?
  objectUri       String
  contextUri      String?
  originUri       String
  originInbox     String?
  targetUri       String
  targetInbox     String
  inReplyTo       String?
  payloadJson     String
  payloadHash     String
  reviewVersionId String?
  resolvedById    String?
  resolutionNote  String?
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?

  reviewVersion ReviewVersion? @relation(fields: [reviewVersionId], references: [id])
  resolvedBy    User?          @relation("federationResolver", fields: [resolvedById], references: [id])

  @@index([direction, status, createdAt])
  @@index([reviewVersionId])
  @@index([inReplyTo])
}
