  zenodoRecordId             String?
  releaseTag                 String?
  releaseUrl                 String?
  /// Public, immutable release/DOI/commit consistency evidence.
  publicationConsistencyJson String?
  /// SHA-256 of the exact canonical inspection capture accepted here.
  capturePayloadHash         String?
  /// True when every DOI/identifier on this version is a synthetic example
  /// (seed/demo data). The UI must not render outbound resolvers for these.
  isExample                  Boolean   @default(false)
  publishedAt                DateTime?
  createdAt                  DateTime  @default(now())
  /// published | withdrawn | tombstoned. Updated only in the same
  /// transaction that appends an attributable lifecycle event.
  publicState                String    @default("published")

  review               Review                 @relation(fields: [reviewId], references: [id])
