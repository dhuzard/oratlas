  id           String   @id @default(cuid())
  submissionId String
  checkId      String
  rationale    String
  editorId     String
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])
  editor     User       @relation(fields: [editorId], references: [id])

  @@unique([submissionId, checkId])
  @@index([editorId])
}

