# --- Database -------------------------------------------------------------
# SQLite for zero-configuration local development. For production, point this
# at PostgreSQL and change the provider in packages/db/prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# --- Sessions ---------------------------------------------------------------
# HMAC secret used to sign session cookies. REQUIRED in production.
# Generate with: openssl rand -hex 32
SESSION_SECRET=""

# --- GitHub inspection ------------------------------------------------------
# Optional. Public repositories work without a token; a token raises the
# GitHub API rate limit from 60 to 5000 requests/hour. Server-side only —
# never exposed to the browser.
GITHUB_TOKEN=""

# --- Authentication ---------------------------------------------------------
# Optional GitHub OAuth app credentials. When absent in development, the app
# offers a clearly-marked development-only mock sign-in instead.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Explicit opt-in for the development mock user. Ignored when NODE_ENV=production.
AUTH_MOCK="1"

# --- Grounded discussion (Atlas Discuss) ------------------------------------
# Optional. When unset, the assistant runs in deterministic mode (structured
# evidence summaries, no generated prose). Provider is isolated behind an
# adapter; only "anthropic" is wired in the POC.
LLM_PROVIDER=""
ANTHROPIC_API_KEY=""
LLM_MODEL="claude-sonnet-5"

# --- Web --------------------------------------------------------------------
# Canonical base URL used for absolute links / Open Graph metadata.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# --- Execution Passports ---------------------------------------------------
# Optional offline trust policy for signed execution attestations. Registration
# fails closed when the signing key/issuer/subject is not listed. keyId is the
# lowercase SHA-256 fingerprint of the Ed25519 public key's DER SPKI bytes.
# JSON: [{"keyId":"…","algorithm":"ed25519","publicKeyPem":"-----BEGIN PUBLIC KEY-----\n…","issuer":"https://token.actions.githubusercontent.com","subject":"https://github.com/OWNER/REPO/.github/workflows/WORKFLOW.yml@refs/heads/main"}]
EXECUTION_PASSPORT_TRUSTED_KEYS_JSON=""
